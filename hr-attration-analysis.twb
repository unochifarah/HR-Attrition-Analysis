              <calculation class='tableau' formula='IF [age] &lt; 25 THEN &quot;Under 25&quot;&#13;&#10;ELSEIF [age] &lt; 35 THEN &quot;25–34&quot;&#13;&#10;ELSEIF [age] &lt; 45 THEN &quot;35–44&quot;&#13;&#10;ELSE &quot;45+&quot;&#13;&#10;END' />
